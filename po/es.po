msgid "Inversée"
msgstr ""

#: data/fr.benjaminbellamy.Inversee.desktop.in:3
#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:12
msgid "Reverse Polish Notation calculator"
msgstr "Calculadora de notación polaca inversa"

#: data/fr.benjaminbellamy.Inversee.desktop.in:4
msgid "RPN;calculator;reverse;polish;notation;HP;maths;"
msgstr "RPN;calculadora;notación;polaca;inversa;HP;matemáticas;"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:15
msgid "Inversée is a Reverse Polish Notation (RPN) calculator with an unbounded stack, designed to look and behave like a native GNOME application."
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:19
msgid "The full stack is visible at all times, values are stored as arbitrary precision MPFR floats, and the locale-aware display follows your system settings."
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:37
msgid "Benjamin Bellamy"
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:52
msgid "Initial scaffold."
msgstr ""

#: src/core/calculator.vala:171
#, c-format
msgid "Binary operation requires 2 operands (have %d)"
msgstr "Operación binaria: se requieren 2 operandos (%d disponibles)"

#: src/core/calculator.vala:200
msgid "Unary operation requires 1 operand"
msgstr "Operación unaria: se requiere 1 operando"

