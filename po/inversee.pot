msgid ""
"GMP and MPFR build with <code>-std=gnu17</code> so they configure cleanly "
"under freedesktop SDK 25.08 (GCC 15)."
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:81
msgid "Runtime moved from end-of-life GNOME 48 to supported GNOME 49."
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:82
msgid ""
"AppStream metainfo: categories, keywords, update contact, and a second "
"screenshot for dark mode."
