msgid "reverse"
msgstr "inversée"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:35
msgid "polish"
msgstr "polonaise"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:36
msgid "notation"
msgstr "notation"

