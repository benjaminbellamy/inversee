#: data/fr.benjaminbellamy.Inversee.desktop.in:2
#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:11 src/ui/window.vala:35
msgid "Inversée"
msgstr ""

#: data/fr.benjaminbellamy.Inversee.desktop.in:3
#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:12
msgid "Reverse Polish Notation calculator"
msgstr "Taschenrechner mit umgekehrter polnischer Notation"

#: data/fr.benjaminbellamy.Inversee.desktop.in:4
msgid "RPN;calculator;reverse;polish;notation;HP;maths;"
msgstr "RPN;UPN;Rechner;Taschenrechner;HP;Mathematik;"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:15
msgid "Inversée is a Reverse Polish Notation (RPN) calculator with an unbounded stack, designed to look and behave like a native GNOME application."
msgstr "Inversée ist ein Taschenrechner mit umgekehrter polnischer Notation (UPN) und unbegrenztem Stapel, der wie eine native GNOME-Anwendung aussehen und sich verhalten soll."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:19
msgid "The full stack is visible at all times, values are stored as arbitrary precision MPFR floats, and the locale-aware display follows your system settings."
msgstr "Der gesamte Stapel ist jederzeit sichtbar, Werte werden als MPFR-Gleitkommazahlen mit beliebiger Genauigkeit gespeichert, und die gebietsschemabewusste Anzeige folgt den Systemeinstellungen."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:32
msgid "RPN"
msgstr "UPN"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:33
msgid "calculator"
msgstr "Rechner"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:34
msgid "reverse"
msgstr "umgekehrt"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:35
msgid "polish"
msgstr "polnisch"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:36
msgid "notation"
msgstr "Notation"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:37
msgid "HP"
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:38
msgid "maths"
msgstr "Mathematik"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:52
msgid "Benjamin Bellamy"
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:67
msgid "The main window in light mode."
msgstr "Das Hauptfenster im hellen Modus."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:71
msgid "The main window in dark mode."
msgstr "Das Hauptfenster im dunklen Modus."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:78
msgid "Maintenance release. Build-pipeline updates only — no user-facing changes."
msgstr "Wartungsversion. Nur Aktualisierungen der Build-Pipeline — keine für den Benutzer sichtbaren Änderungen."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:80
msgid "GMP and MPFR build with <code>-std=gnu17</code> so they configure cleanly under freedesktop SDK 25.08 (GCC 15)."
msgstr "GMP und MPFR werden mit <code>-std=gnu17</code> kompiliert, damit sie unter freedesktop SDK 25.08 (GCC 15) sauber konfigurieren."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:81
msgid "Runtime moved from end-of-life GNOME 48 to supported GNOME 49."
msgstr "Laufzeit von der eingestellten GNOME 48 auf unterstützte GNOME 49 verschoben."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:82
msgid "AppStream metainfo: categories, keywords, update contact, and a second screenshot for dark mode."
msgstr "AppStream-Metainfo: Kategorien, Schlüsselwörter, Update-Kontakt und ein zweiter Screenshot für den dunklen Modus."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:83
msgid "CI: tagged pushes now auto-upload the Flatpak bundle to the matching GitHub Release."
msgstr "CI: Tag-Pushes laden den Flatpak-Bundle jetzt automatisch in die passende GitHub-Veröffentlichung hoch."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:89
msgid "First public release."
msgstr "Erste öffentliche Veröffentlichung."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:91
msgid "Unbounded RPN stack with swap, drop, rot, dup, dup2 and clear."
msgstr "Unbegrenzter UPN-Stapel mit swap, drop, rot, dup, dup2 und clear."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:92
msgid "Arbitrary-precision arithmetic via MPFR (128-bit internal)."
msgstr "Arithmetik mit beliebiger Genauigkeit über MPFR (128 Bit intern)."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:93
msgid "Full operation set: + − × ÷ mod %, x^y, √, 1/x, +/−."
msgstr "Vollständiger Operationssatz: + − × ÷ mod %, x^y, √, 1/x, +/−."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:94
msgid "Unbounded undo, capped at 1000 entries per session."
msgstr "Unbegrenztes Rückgängigmachen, auf 1000 Einträge pro Sitzung begrenzt."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:95
msgid "Locale-aware display, locale-tolerant clipboard paste."
msgstr "Gebietsschemabewusste Anzeige, gebietsschematolerantes Einfügen aus der Zwischenablage."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:96
msgid "Clipboard menu: paste, copy X, copy whole stack."
msgstr "Zwischenablage-Menü: einfügen, X kopieren, ganzen Stapel kopieren."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:97
msgid "Session persistence to $XDG_DATA_HOME/inversee/state.json."
msgstr "Sitzungspersistenz nach $XDG_DATA_HOME/inversee/state.json."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:98
msgid "Window geometry and chosen UI language persisted via GSettings."
msgstr "Fenstergeometrie und gewählte UI-Sprache werden über GSettings gespeichert."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:99
msgid "Translations: English, French, German, Italian, Spanish, Dutch, Polish, Portuguese."
msgstr "Übersetzungen: Englisch, Französisch, Deutsch, Italienisch, Spanisch, Niederländisch, Polnisch, Portugiesisch."

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:105
msgid "Initial scaffold."
msgstr "Erstes Gerüst."

