#: data/fr.benjaminbellamy.Inversee.desktop.in:3
#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:12
msgid "Reverse Polish Notation calculator"
msgstr "Calculadora de notação polaca inversa"

#: data/fr.benjaminbellamy.Inversee.desktop.in:4
msgid "RPN;calculator;reverse;polish;notation;HP;maths;"
msgstr "RPN;calculadora;notação;polaca;inversa;HP;matemática;"

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:15
msgid ""
"Inversée is a Reverse Polish Notation (RPN) calculator with an unbounded "
"stack, designed to look and behave like a native GNOME application."
msgstr ""

#: data/fr.benjaminbellamy.Inversee.metainfo.xml.in:19
msgid ""
"The full stack is visible at all times, values are stored as arbitrary "
"precision MPFR floats, and the locale-aware display follows your system "
"settings."
msgstr ""

