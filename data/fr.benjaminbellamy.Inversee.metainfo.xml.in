<component type="desktop-application">
  <id>fr.benjaminbellamy.Inversee</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Inversée</name>
  <summary>Reverse Polish Notation calculator</summary>

  <description>
    <p>
      Inversée is a Reverse Polish Notation (RPN) calculator with an unbounded
      stack, designed to look and behave like a native GNOME application.
    </p>
    <p>
      The full stack is visible at all times, values are stored as arbitrary
      precision MPFR floats, and the locale-aware display follows your
      system settings.
    </p>
  </description>

  <categories>
    <category>Utility</category>
    <category>Calculator</category>
  </categories>

  <keywords>
    <keyword>RPN</keyword>
    <keyword>calculator</keyword>
    <keyword>reverse</keyword>
    <keyword>polish</keyword>
    <keyword>notation</keyword>
    <keyword>HP</keyword>
    <keyword>maths</keyword>
  </keywords>

  <launchable type="desktop-id">fr.benjaminbellamy.Inversee.desktop</launchable>

  <provides>
    <binary>inversee</binary>
  </provides>

  <url type="homepage">https://github.com/benjaminbellamy/inversee</url>
  <url type="bugtracker">https://github.com/benjaminbellamy/inversee/issues</url>
  <url type="vcs-browser">https://github.com/benjaminbellamy/inversee</url>

  <developer id="fr.benjaminbellamy">
    <name>Benjamin Bellamy</name>
  </developer>

  <update_contact>benjamin_AT_castopod.org</update_contact>

  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#cf354f</color>
    <color type="primary" scheme_preference="dark">#5e5e5e</color>
  </branding>

  <screenshots>
    <screenshot type="default" environment="gnome">
      <image>https://raw.githubusercontent.com/benjaminbellamy/inversee/main/data/screenshots/screenshot.png</image>
      <caption>The main window in light mode.</caption>
    </screenshot>
    <screenshot environment="gnome:dark">
      <image>https://raw.githubusercontent.com/benjaminbellamy/inversee/main/data/screenshots/screenshot_dark.png</image>
      <caption>The main window in dark mode.</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.0.0" date="2026-05-13">
      <description>
        <p>First public release.</p>
        <ul>
          <li>Unbounded RPN stack with swap, drop, rot, dup, dup2 and clear.</li>
          <li>Arbitrary-precision arithmetic via MPFR (128-bit internal).</li>
          <li>Full operation set: + − × ÷ mod %, x^y, √, 1/x, +/−.</li>
          <li>Unbounded undo, capped at 1000 entries per session.</li>
          <li>Locale-aware display, locale-tolerant clipboard paste.</li>
          <li>Clipboard menu: paste, copy X, copy whole stack.</li>
          <li>Session persistence to $XDG_DATA_HOME/inversee/state.json.</li>
          <li>Window geometry and chosen UI language persisted via GSettings.</li>
          <li>Translations: English, French, German, Italian, Spanish, Dutch, Polish, Portuguese.</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-05-12">
      <description>
        <p>Initial scaffold.</p>
      </description>
    </release>
  </releases>
</component>
